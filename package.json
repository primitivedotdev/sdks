{
  "name": "@primitivedotdev/sdk-node",
  "version": "0.1.0",
  "description": "Official Primitive Node.js SDK — email parser, types, webhook verification",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "default": "./dist/parser/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "default": "./dist/webhook/index.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "default": "./dist/zod.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:schema": "tsx scripts/generate-schema.ts",
    "build": "pnpm generate:schema && tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "primitive",
    "email",
    "webhook",
    "signature",
    "hmac",
    "parser"
  ],
  "author": "Primitive <support@primitive.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/primitivedotdev/sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/primitivedotdev/sdk-node/issues"
  },
  "homepage": "https://primitive.dev",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "mailparser": "^3.9.0",
    "isomorphic-dompurify": "^2.34.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/archiver": "^7.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "ts-json-schema-generator": "^2.4.0",
    "tsdown": "^0.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
