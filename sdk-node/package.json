{
  "name": "@primitivedotdev/sdk",
  "version": "0.3.0",
  "description": "Official Primitive Node.js SDK — webhook, api, openapi, contract, and parser modules",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "import": "./dist/webhook/index.js",
      "default": "./dist/webhook/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "default": "./dist/api/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi/index.d.ts",
      "import": "./dist/openapi/index.js",
      "default": "./dist/openapi/index.js"
    },
    "./contract": {
      "types": "./dist/contract/index.d.ts",
      "import": "./dist/contract/index.js",
      "default": "./dist/contract/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js",
      "default": "./dist/parser/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "bin": {
    "primitive": "./bin/run.js"
  },
  "oclif": {
    "bin": "primitive",
    "commands": {
      "strategy": "explicit",
      "target": "./dist/oclif/index.js",
      "identifier": "COMMANDS"
    },
    "dirname": "primitive",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-autocomplete"
    ],
    "topics": {
      "account": {
        "description": "Manage your account settings, storage, and webhook secret"
      },
      "domains": {
        "description": "Claim, verify, and manage email domains"
      },
      "emails": {
        "description": "List, inspect, and manage received emails"
      },
      "endpoints": {
        "description": "Manage webhook endpoints that receive email events"
      },
      "filters": {
        "description": "Manage whitelist and blocklist filter rules"
      },
      "webhook-deliveries": {
        "description": "View and replay webhook delivery attempts"
      }
    },
    "topicSeparator": " "
  },
  "scripts": {
    "generate:openapi": "tsx scripts/generate-openapi-artifacts.ts",
    "generate:api": "openapi-ts -f openapi-ts.config.ts && tsx scripts/fix-generated-api-imports.ts",
    "generate:schema": "tsx scripts/generate-schema-module.ts",
    "generate:types": "tsx scripts/generate-types.ts",
    "generate:validator": "tsx scripts/generate-validator.ts",
    "generate": "pnpm generate:openapi && pnpm generate:api && pnpm generate:schema && pnpm generate:types && pnpm generate:validator",
    "build:library": "pnpm generate && tsdown",
    "build:oclif": "tsc -p tsconfig.oclif.json",
    "build": "pnpm build:library && pnpm build:oclif",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "pnpm generate && tsc --noEmit -p tsconfig.typecheck.json",
    "lint": "biome check --error-on-warnings src/index.ts src/validation.ts src/types.ts src/webhook src/contract src/parser src/api/index.ts src/openapi/index.ts src/oclif tests/",
    "lint:fix": "biome check --write --error-on-warnings src/index.ts src/validation.ts src/types.ts src/webhook src/contract src/parser src/api/index.ts src/openapi/index.ts src/oclif tests/",
    "prepack": "pnpm build && oclif manifest",
    "postpack": "shx rm -f oclif.manifest.json",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "primitive",
    "api",
    "email",
    "openapi",
    "webhook",
    "signature",
    "hmac",
    "contract",
    "parser"
  ],
  "author": "Primitive <support@primitive.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/primitivedotdev/sdks.git",
    "directory": "sdk-node"
  },
  "bugs": {
    "url": "https://github.com/primitivedotdev/sdks/issues"
  },
  "homepage": "https://primitive.dev",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@oclif/core": "^4.10.5",
    "@oclif/plugin-autocomplete": "^3.2.45",
    "@oclif/plugin-help": "^6.2.44",
    "ajv": "^8.17.1",
    "isomorphic-dompurify": "^3.8.0",
    "mailparser": "^3.9.0",
    "tar-stream": "^3.1.8"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.96.0",
    "@biomejs/biome": "^2.4.10",
    "@types/json-schema": "^7.0.15",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.2",
    "@types/tar-stream": "^3.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "json-schema-to-typescript": "^15.0.4",
    "oclif": "^4.23.0",
    "shx": "^0.3.4",
    "tsdown": "^0.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "yaml": "^2.8.1"
  }
}
