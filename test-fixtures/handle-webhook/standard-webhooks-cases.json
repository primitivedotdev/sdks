{
  "cases": [
    {
      "name": "valid_standard_webhooks",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "{timestamp}",
        "webhook-signature": "{signed_standard}"
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "expected": {
        "valid": true,
        "id": "evt_0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
      }
    },
    {
      "name": "valid_standard_webhooks_uppercase_headers",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "Webhook-Id": "msg_test123",
        "Webhook-Timestamp": "{timestamp}",
        "Webhook-Signature": "{signed_standard}"
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "expected": {
        "valid": true,
        "id": "evt_0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
      }
    },
    {
      "name": "wrong_secret_standard_webhooks",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "{timestamp}",
        "webhook-signature": "{signed_standard}"
      },
      "secret": "whsec_dGVzdF9zZWNyZXRfa2V5XzEyMw==",
      "sign_secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "expected": {
        "valid": false,
        "error_code": "SIGNATURE_MISMATCH"
      }
    },
    {
      "name": "expired_standard_webhooks",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "{timestamp}",
        "webhook-signature": "{signed_standard}"
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "timestamp": 1734567000,
      "expected": {
        "valid": false,
        "error_code": "TIMESTAMP_OUT_OF_RANGE"
      }
    },
    {
      "name": "missing_webhook_id",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-timestamp": "1734567890",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "expected": {
        "valid": false,
        "error_code": "INVALID_SIGNATURE_HEADER"
      }
    },
    {
      "name": "missing_webhook_timestamp",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "expected": {
        "valid": false,
        "error_code": "INVALID_SIGNATURE_HEADER"
      }
    },
    {
      "name": "invalid_json_body_standard_webhooks",
      "body": "{\"event\":\"email.received\"",
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "{timestamp}",
        "webhook-signature": "{signed_standard}"
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "expected": {
        "valid": false,
        "error_code": "JSON_PARSE_FAILED"
      }
    },
    {
      "name": "schema_invalid_standard_webhooks",
      "body": "{\"event\":\"email.received\",\"id\":\"evt_only\"}",
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "{timestamp}",
        "webhook-signature": "{signed_standard}"
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "msg_id": "msg_test123",
      "expected": {
        "valid": false,
        "error_code": "SCHEMA_VALIDATION_FAILED"
      }
    },
    {
      "name": "empty_secret",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "1734567890",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "",
      "expected": {
        "valid": false,
        "error_code": "MISSING_SECRET"
      }
    },
    {
      "name": "bare_whsec_prefix_secret",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "1734567890",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_",
      "expected": {
        "valid": false,
        "error_code": "MISSING_SECRET"
      }
    },
    {
      "name": "padding_only_secret",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "1734567890",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_==",
      "expected": {
        "valid": false,
        "error_code": "MISSING_SECRET"
      }
    },
    {
      "name": "invalid_base64_secret",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "1734567890",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_not!valid!base64",
      "expected": {
        "valid": false,
        "error_code": "MISSING_SECRET"
      }
    },
    {
      "name": "empty_webhook_signature_value",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "1734567890",
        "webhook-signature": ""
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "expected": {
        "valid": false,
        "error_code": "INVALID_SIGNATURE_HEADER"
      }
    },
    {
      "name": "non_numeric_timestamp",
      "body_fixture": ["webhook", "valid-email-received.json"],
      "headers": {
        "webhook-id": "msg_test123",
        "webhook-timestamp": "not-a-number",
        "webhook-signature": "v1,AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
      },
      "secret": "whsec_MfKQ9r8GKYqrTwjUPD8ILPZIo2LaLaSw",
      "expected": {
        "valid": false,
        "error_code": "INVALID_SIGNATURE_HEADER"
      }
    }
  ]
}
